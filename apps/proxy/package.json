{
  "name": "@proxy/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/app.ts",
    "build": "bun build src/app.ts --outdir dist --target bun",
    "start": "bun run dist/app.js",
    "lint": "oxlint src/",
    "test": "bun test src/__tests__",
    "test:watch": "bun test --watch src/__tests__",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@enkryptify/sdk": "^0.1.2",
    "@hono/zod-openapi": "^1.3.0",
    "@hono/zod-validator": "latest",
    "@proxy/types": "workspace:*",
    "@t3-oss/env-core": "^0.13.11",
    "drizzle-orm": "latest",
    "hono": "latest",
    "postgres": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "latest"
  }
}
