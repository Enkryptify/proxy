# Local / Docker
PORT=3000
DATABASE_URL=postgres://user:pass@localhost:5432/proxy
DATABASE_LOGGING=false
DATABASE_MIGRATE_ON_START=false
NODE_ENV=development

# Admin panel (apps/web)
ADMIN_WEB_ORIGINS=http://localhost:5173
JWT_ACCESS_SECRET=replace-with-32+-byte-random-string
JWT_REFRESH_SECRET=replace-with-a-DIFFERENT-32+-byte-random-string
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
COOKIE_SECURE=false

# Monorepo dev / Vercel: include admin panel when not "false" (see README).
# ENABLE_ADMIN_WEB=true

# Enkryptify vault (required for admin panel workspace resolve + proxy auth header)
# PROXY_KEY=ek_live_replace_me
# ENKRYPTIFY_API_URL=https://api.enkryptify.com

