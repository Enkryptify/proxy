# Local / Docker
PORT=3000
DATABASE_URL=postgres://user:pass@localhost:5432/proxy
DATABASE_LOGGING=false
DATABASE_MIGRATE_ON_START=false
NODE_ENV=development

# Vercel — https://bun.com/docs/guides/deployment/vercel
# Set Root Directory to apps/proxy in the Vercel dashboard, then:
#   cd apps/proxy && bun run deploy:vercel
#
# DATABASE_URL is optional when DATABASE_LOGGING=false.
