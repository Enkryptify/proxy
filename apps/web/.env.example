# Where Vite forwards /api requests during `vite dev`. Default: http://localhost:3000
# VITE_PROXY_TARGET=http://localhost:3000

# Used in `vite build` output (production). Default: same-origin /api.
# When the admin panel is served from a different host than the proxy, set this
# to the absolute origin: e.g. https://proxy.example.com
VITE_API_BASE_URL=
