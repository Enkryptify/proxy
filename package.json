{
  "name": "proxy-monorepo",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "oxfmt": "oxlint --fix .",
    "format": "prettier --write .",
