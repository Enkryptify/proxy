aws_region                 = "eu-central-1"
name_prefix                = "proxy-prod"
vpc_id                     = "vpc-xxxxxxxx"
public_subnet_ids          = ["subnet-aaaa", "subnet-bbbb"]
private_subnet_ids         = ["subnet-cccc", "subnet-dddd"]
container_image            = "123456789012.dkr.ecr.eu-central-1.amazonaws.com/proxy-api:latest"
database_url_secret_arn    = "arn:aws:secretsmanager:eu-central-1:123456789012:secret:proxy/prod/database_url-xxxxxx"
database_logging           = true
database_migrate_on_start  = false
desired_count              = 1
cpu                        = 512
memory                     = 1024
health_check_path          = "/health"
create_ecr_repository      = true
ecr_repository_name        = "proxy-api"
acm_certificate_arn        = null
hosted_zone_id             = null
domain_name                = null
